<!-- Wazuh local rules for SIEM Detection Lab. Review IDs before production use. -->
<group name="siem_lab,windows,">

  <rule id="100100" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine">(?i)-enc|-encodedcommand</field>
    <description>SIEM Lab: Suspicious PowerShell encoded command detected</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <rule id="100101" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">4732</field>
    <description>SIEM Lab: User added to a local security group</description>
    <mitre>
      <id>T1136</id>
    </mitre>
  </rule>

</group>
